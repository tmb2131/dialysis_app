# Use the same Supabase project as production (copy URL + publishable or anon key from the dashboard
# or from your Vercel/hosting env). `next dev` expects these unless you opt into a local stack below.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Newer publishable key (sb_publishable_…) or legacy anon JWT both work.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Optional: some CI and Supabase templates use the names below; they are read in src/lib/supabase/env.ts and mirrored in next.config.ts
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
#
# Local `supabase start` only — not the hosted production DB:
# SUPABASE_USE_LOCAL_DEV=1
